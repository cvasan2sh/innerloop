{
  "rewrites": [
    { "source": "/in", "destination": "/in/index.html" },
    { "source": "/us", "destination": "/us/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
